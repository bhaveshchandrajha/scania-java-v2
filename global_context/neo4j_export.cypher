// params {"name": "SDE001", "library": "S400LMODS", "col_name": "MSG 2"}
MERGE (c:Column {name: $name, sqlType: $sqlType, length: $length, scale: $scale}) ON CREATE SET c.key = $key ON MATCH SET  c.key = coalesce(c.key, $key);
// params {"name": "MSG 3", "sqlType": "CHAR(33)", "length": 33, "scale": null, "key": false}
MATCH (f:DbFile {name: $name, library: $library}),       (c:Column {name: $col_name}) MERGE (f)-[:HAS_COLUMN]->(c);
// params {"name": "SDE001", "library": "S400LMODS", "col_name": "MSG 3"}
MERGE (p:Program {programId: $programId}) ON CREATE SET p.unitId = $unitId ON MATCH SET  p.unitId = coalesce(p.unitId, $unitId);
// params {"programId": "HS1210", "unitId": "qsys:HSSRC/QRPGLESRC/HS1210"}
MERGE (n:Node {nodeId: $nodeId}) ON CREATE SET n.kind = $kind, n.name = $name, n.programId = $programId ON MATCH SET  n.kind = coalesce(n.kind, $kind),               n.name = coalesce(n.name, $name),               n.programId = coalesce(n.programId, $programId);
// params {"nodeId": "n1", "kind": "CompilationUnit", "name": null, "programId": "HS1210"}
MATCH (p:Program {programId: $programId}), (n:Node {nodeId: $nodeId}) MERGE (p)-[:HAS_NODE]->(n);
